# =========================================================
# 오토벤딩 환경변수 예시 파일
# 이 파일을 복사해서 .env.local 로 저장한 뒤 값을 채우세요.
#
#   macOS / Linux:  cp .env.local.example .env.local
#   Windows:        copy .env.local.example .env.local
#
# .env.local 은 절대 GitHub 에 커밋하지 마세요.
# (이미 .gitignore 에 등록되어 있습니다.)
# =========================================================

# ------ /setup 페이지로 저장하는 값을 암호화하는 키 ------
# 32바이트 이상 랜덤 문자열. 한 번 정하면 바꾸지 마세요.
# 생성 예시:
#   macOS/Linux:  openssl rand -base64 32
#   Windows PS:   [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
APP_ENCRYPTION_KEY=

# ------ OpenAI (AI 결과 생성) ------
# 없으면 mock 결과로 동작합니다. /setup 페이지에서도 저장 가능.
OPENAI_API_KEY=

# ------ SMTP (이메일 전송) ------
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# SMTP_PASS 는 Gmail "앱 비밀번호" 사용. (계정 비밀번호 X)
# 없으면 mock 모드로 동작합니다.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DEFAULT_TO_EMAIL=

# ------ 카카오톡 나에게 보내기 ------
# 카카오 개발자 콘솔에서 talk_message scope 로 발급한 user access token.
# 토큰은 보통 수 시간 유효. 만료되면 재발급.
# 없으면 mock 모드로 동작합니다.
KAKAO_ACCESS_TOKEN=

# ------ 기타 ------
# 카카오톡 메시지 "웹에서 보기" 버튼의 링크 베이스
NEXT_PUBLIC_APP_URL=http://localhost:3000
