# =========================================================
# HI AI LAB 환경변수 예시 파일
# 이 파일을 복사해서 .env.local 로 저장한 뒤 값을 채우세요.
#
#   macOS / Linux:  cp .env.local.example .env.local
#   Windows:        copy .env.local.example .env.local
#
# .env.local 은 절대 GitHub 에 커밋하지 마세요.
# (이미 .gitignore 에 등록되어 있습니다.)
# =========================================================

# ------ /setup 페이지로 저장하는 값을 암호화하는 키 ------
# 32바이트 이상 랜덤 문자열. 한 번 정하면 바꾸지 마세요.
# 생성 예시:
#   macOS/Linux:  openssl rand -base64 32
#   Windows PS:   [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
APP_ENCRYPTION_KEY=

# ------ AI 키 (Gemini 또는 OpenAI 중 하나만 있으면 됨, 둘 다 있으면 Gemini 우선) ------
# Google Gemini — 무료 quota 큼 (분당 15회 / 일 1500회). 결제 없이 사용 가능.
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — pay-as-you-go (별도 결제 필요)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ------ SMTP (이메일 전송) ------
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# SMTP_PASS 는 Gmail "앱 비밀번호" 사용. (계정 비밀번호 X)
# 없으면 mock 모드로 동작합니다.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DEFAULT_TO_EMAIL=

# ------ 카카오톡 나에게 보내기 ------
# 카카오 개발자 콘솔에서 talk_message scope 로 발급한 user access token.
# 토큰은 보통 수 시간 유효. 만료되면 재발급.
# 없으면 mock 모드로 동작합니다.
KAKAO_ACCESS_TOKEN=

# ------ 소유자 제한 (단일 사용자용) ------
# 비워두면 누구나 OAuth 가능 (로컬 테스트 가정).
# 채워두면 이 이메일로 OAuth 로그인한 경우만 Gmail 연결 가능. (서버 공개 배포 시 권장)
OWNER_EMAIL=

# ------ Gmail 자동화 (OAuth) — /agent 페이지 사용 시 ------
# Google Cloud Console에서 OAuth 2.0 클라이언트 ID를 발급받아 입력.
# 셀프호스팅이라 각자 본인 Google Cloud 프로젝트를 만들면 검수 없이 사용 가능.
# 자세한 절차: docs/SETUP_GMAIL_AUTOMATION.md
# /setup 페이지에서도 입력 가능 (그쪽이 더 편함).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 폴링 주기 (초). 기본 300초(5분). 너무 짧으면 OpenAI/Gmail API 호출이 늘어남.
AGENT_POLL_INTERVAL_SEC=300

# ------ 기타 ------
# 카카오톡 메시지 "웹에서 보기" 버튼의 링크 베이스.
# Gmail OAuth callback URI도 이 값을 기준으로 계산:
#   ${NEXT_PUBLIC_APP_URL}/api/gmail/callback
# 서버 배포 시: https://your-subdomain.example.com 으로 변경.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Docker 호스트 포트 — 다른 서비스가 3000을 쓰면 충돌 피해 변경
# (예: 3100, 3200 등) docker compose 가 이 값을 호스트 매핑에 사용
HOST_PORT=3000
